{
  "manifest_version": 3,
  "name": "CoeurVers - New Tab",
  "version": "1.0.0",
  "description": "A beautiful, highly customizable new tab page with aesthetic wallpapers, smart shortcut grid, search suggestions, and zen clock.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://suggestqueries.google.com/*",
    "https://api.bing.com/*",
    "https://suggestion.baidu.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}